generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum EmploymentStatus {
  ACTIVE
  ON_PROBATION
  INACTIVE
  RESIGNED
  TERMINATED
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum EmployeeDocumentType {
  AADHAAR
  PAN
  RESUME
  OFFER_LETTER
  EXPERIENCE_LETTER
  CERTIFICATE
  OTHER
}

enum TeamMemberRole {
  TEAM_LEAD
  MEMBER
  INTERN
  FREELANCER
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("roles")
}

model Department {
  id           String        @id @default(uuid())
  name         String        @unique
  description  String?
  employees    Employee[]
  designations Designation[]
  teams        Team[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("departments")
}

model Designation {
  id           String      @id @default(uuid())
  name         String
  description  String?
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  employees    Employee[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([name, departmentId])
  @@map("designations")
}

model Team {
  id           String       @id @default(uuid())
  name         String
  description  String?
  departmentId String
  department   Department   @relation(fields: [departmentId], references: [id])
  members      TeamMember[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([name, departmentId])
  @@map("teams")
}

model TeamMember {
  id         String         @id @default(uuid())
  teamId     String
  employeeId String
  role       TeamMemberRole @default(MEMBER)
  joinedAt   DateTime       @default(now())

  team     Team     @relation(fields: [teamId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([teamId, employeeId])
  @@map("team_members")
}

model ReportingHierarchy {
  id          String  @id @default(uuid())
  employeeId  String  @unique
  reportsToId String?

  employee  Employee  @relation("ReportingEmployee", fields: [employeeId], references: [id])
  reportsTo Employee? @relation("ReportingManager", fields: [reportsToId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reporting_hierarchy")
}

model EmployeeDocument {
  id         String               @id @default(uuid())
  employeeId String
  type       EmployeeDocumentType @default(OTHER)
  name       String
  fileUrl    String?
  fileKey    String?
  notes      String?

  employee Employee @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("employee_documents")
}

model EmployeeSkill {
  id                String     @id @default(uuid())
  employeeId        String
  skillName         String
  level             SkillLevel @default(BEGINNER)
  yearsOfExperience Float?
  notes             String?

  employee Employee @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, skillName])
  @@map("employee_skills")
}

model EmployeeSalaryDetail {
  id            String    @id @default(uuid())
  employeeId    String
  basicSalary   Float
  hra           Float     @default(0)
  allowances    Float     @default(0)
  deductions    Float     @default(0)
  netSalary     Float
  effectiveFrom DateTime
  effectiveTo   DateTime?
  isCurrent     Boolean   @default(true)

  employee Employee @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("employee_salary_details")
}

model User {
  id       String     @id @default(uuid())
  name     String
  email    String     @unique
  phone    String?
  password String
  status   UserStatus @default(ACTIVE)

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  employee Employee?

  loginHistory     LoginHistory[]
  deviceSessions   DeviceSession[]
  otpVerifications OtpVerification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Employee {
  id           String @id @default(uuid())
  userId       String @unique
  employeeCode String @unique

  designationId String?
  designation   Designation? @relation(fields: [designationId], references: [id])

  reportingAsEmployee ReportingHierarchy[] @relation("ReportingEmployee")
  reportingAsManager  ReportingHierarchy[] @relation("ReportingManager")

  joiningDate      DateTime?
  salary           Float?
  skills           String?
  employmentStatus EmploymentStatus @default(ACTIVE)

  managerId    String?
  manager      Employee?  @relation("EmployeeManager", fields: [managerId], references: [id])
  subordinates Employee[] @relation("EmployeeManager")

  documents      EmployeeDocument[]
  employeeSkills EmployeeSkill[]
  salaryDetails  EmployeeSalaryDetail[]

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  user User @relation(fields: [userId], references: [id])

  teamMemberships TeamMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("employees")
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String
  ipAddress String?
  device    String?
  browser   String?
  os        String?
  loginAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("login_history")
}

model DeviceSession {
  id           String   @id @default(uuid())
  userId       String
  deviceName   String?
  ipAddress    String?
  token        String?
  isActive     Boolean  @default(true)
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("device_sessions")
}

model OtpVerification {
  id        String   @id @default(uuid())
  userId    String?
  email     String
  otp       String
  purpose   String
  isUsed    Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("otp_verifications")
}
