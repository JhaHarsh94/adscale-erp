generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum EmploymentStatus {
  ACTIVE
  ON_PROBATION
  INACTIVE
  RESIGNED
  TERMINATED
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum EmployeeDocumentType {
  AADHAAR
  PAN
  RESUME
  OFFER_LETTER
  EXPERIENCE_LETTER
  CERTIFICATE
  OTHER
}

enum TeamMemberRole {
  TEAM_LEAD
  MEMBER
  INTERN
  FREELANCER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LATE
  ON_LEAVE
}

enum AttendanceMethod {
  NORMAL
  QR
  SELFIE
  GPS
  BIOMETRIC
  MANUAL
}

enum AttendanceRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BiometricProvider {
  WEBAUTHN
  MANTRA
  SECUGEN
  ZKTECO
  ESSL
  OTHER
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("roles")
}

model Department {
  id           String        @id @default(uuid())
  name         String        @unique
  description  String?
  employees    Employee[]
  designations Designation[]
  teams        Team[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("departments")
}

model Designation {
  id           String      @id @default(uuid())
  name         String
  description  String?
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  employees    Employee[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([name, departmentId])
  @@map("designations")
}

model Team {
  id           String       @id @default(uuid())
  name         String
  description  String?
  departmentId String
  department   Department   @relation(fields: [departmentId], references: [id])
  members      TeamMember[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([name, departmentId])
  @@map("teams")
}

model TeamMember {
  id         String         @id @default(uuid())
  teamId     String
  employeeId String
  role       TeamMemberRole @default(MEMBER)
  joinedAt   DateTime       @default(now())

  team     Team     @relation(fields: [teamId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([teamId, employeeId])
  @@map("team_members")
}

model ReportingHierarchy {
  id          String  @id @default(uuid())
  employeeId  String  @unique
  reportsToId String?

  employee  Employee  @relation("ReportingEmployee", fields: [employeeId], references: [id])
  reportsTo Employee? @relation("ReportingManager", fields: [reportsToId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reporting_hierarchy")
}

model EmployeeDocument {
  id         String               @id @default(uuid())
  employeeId String
  type       EmployeeDocumentType @default(OTHER)
  name       String
  fileUrl    String?
  fileKey    String?
  notes      String?

  employee Employee @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("employee_documents")
}

model EmployeeSkill {
  id                String     @id @default(uuid())
  employeeId        String
  skillName         String
  level             SkillLevel @default(BEGINNER)
  yearsOfExperience Float?
  notes             String?

  employee Employee @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, skillName])
  @@map("employee_skills")
}

model EmployeeSalaryDetail {
  id            String    @id @default(uuid())
  employeeId    String
  basicSalary   Float
  hra           Float     @default(0)
  allowances    Float     @default(0)
  deductions    Float     @default(0)
  netSalary     Float
  effectiveFrom DateTime
  effectiveTo   DateTime?
  isCurrent     Boolean   @default(true)

  employee Employee @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("employee_salary_details")
}

model User {
  id       String     @id @default(uuid())
  name     String
  email    String     @unique
  phone    String?
  password String
  status   UserStatus @default(ACTIVE)

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  employee Employee?

  loginHistory     LoginHistory[]
  deviceSessions   DeviceSession[]
  otpVerifications OtpVerification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Employee {
  id           String @id @default(uuid())
  userId       String @unique
  employeeCode String @unique

  designationId String?
  designation   Designation? @relation(fields: [designationId], references: [id])

  reportingAsEmployee ReportingHierarchy[] @relation("ReportingEmployee")
  reportingAsManager  ReportingHierarchy[] @relation("ReportingManager")

  joiningDate      DateTime?
  salary           Float?
  skills           String?
  employmentStatus EmploymentStatus @default(ACTIVE)

  managerId    String?
  manager      Employee?  @relation("EmployeeManager", fields: [managerId], references: [id])
  subordinates Employee[] @relation("EmployeeManager")

  documents      EmployeeDocument[]
  employeeSkills EmployeeSkill[]
  salaryDetails  EmployeeSalaryDetail[]

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  user User @relation(fields: [userId], references: [id])

  teamMemberships TeamMember[]

  attendances          Attendance[]
  attendanceRequests   AttendanceRequest[]
  biometricEnrollments BiometricEnrollment[]
  biometricLogs        BiometricAttendanceLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("employees")
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String
  ipAddress String?
  device    String?
  browser   String?
  os        String?
  loginAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("login_history")
}

model Attendance {
  id             String   @id @default(uuid())
  employeeId     String
  attendanceDate DateTime

  checkInTime  DateTime?
  checkOutTime DateTime?

  checkInMethod  AttendanceMethod?
  checkOutMethod AttendanceMethod?

  totalBreakMins Int @default(0)
  totalWorkMins  Int @default(0)

  status    AttendanceStatus @default(PRESENT)
  isLate    Boolean          @default(false)
  isHalfDay Boolean          @default(false)

  checkInQrSessionId  String?
  checkOutQrSessionId String?

  checkInSelfieUrl  String?
  checkOutSelfieUrl String?

  checkInLatitude   Float?
  checkInLongitude  Float?
  checkOutLatitude  Float?
  checkOutLongitude Float?

  checkInAccuracyM  Float?
  checkOutAccuracyM Float?

  checkInLocationVerified  Boolean @default(false)
  checkOutLocationVerified Boolean @default(false)

  checkInBiometricVerified  Boolean @default(false)
  checkOutBiometricVerified Boolean @default(false)

  checkInBiometricDeviceId  String?
  checkOutBiometricDeviceId String?

  checkInBiometricUserId  String?
  checkOutBiometricUserId String?

  checkInBiometricLogId  String?
  checkOutBiometricLogId String?

  ipAddress  String?
  deviceInfo String?
  notes      String?

  employee Employee          @relation(fields: [employeeId], references: [id])
  breaks   AttendanceBreak[]

  checkInQrSession  AttendanceQrSession? @relation("CheckInQrSession", fields: [checkInQrSessionId], references: [id])
  checkOutQrSession AttendanceQrSession? @relation("CheckOutQrSession", fields: [checkOutQrSessionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, attendanceDate])
  @@map("attendance")
}

model AttendanceBreak {
  id           String    @id @default(uuid())
  attendanceId String
  breakStart   DateTime
  breakEnd     DateTime?
  durationMins Int       @default(0)
  notes        String?

  attendance Attendance @relation(fields: [attendanceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("attendance_breaks")
}

model AttendanceSetting {
  id              String @id @default(uuid())
  officeStartTime String @default("10:00")
  officeEndTime   String @default("19:00")
  lateAfterMins   Int    @default(15)
  halfDayMins     Int    @default(270)
  fullDayMins     Int    @default(480)

  officeLatitude  Float?
  officeLongitude Float?
  gpsRadiusMeters Int    @default(200)

  allowNormalAttendance      Boolean @default(true)
  requireQrAttendance        Boolean @default(false)
  requireSelfieAttendance    Boolean @default(false)
  requireGpsAttendance       Boolean @default(false)
  requireBiometricAttendance Boolean @default(false)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("attendance_settings")
}

model AttendanceQrSession {
  id        String   @id @default(uuid())
  token     String   @unique
  title     String?
  validFrom DateTime
  expiresAt DateTime
  isActive  Boolean  @default(true)

  createdById String?
  notes       String?

  checkInAttendances  Attendance[] @relation("CheckInQrSession")
  checkOutAttendances Attendance[] @relation("CheckOutQrSession")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("attendance_qr_sessions")
}

model AttendanceRequest {
  id             String                  @id @default(uuid())
  employeeId     String
  attendanceDate DateTime
  requestType    String
  reason         String?
  status         AttendanceRequestStatus @default(PENDING)

  requestedCheckInTime  DateTime?
  requestedCheckOutTime DateTime?

  approvedById String?
  approvedAt   DateTime?
  remarks      String?

  employee Employee @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("attendance_requests")
}

model BiometricDevice {
  id           String            @id @default(uuid())
  name         String
  provider     BiometricProvider @default(OTHER)
  model        String?
  serialNumber String?           @unique
  location     String?
  apiBaseUrl   String?
  apiKey       String?
  isActive     Boolean           @default(true)

  enrollments BiometricEnrollment[]
  logs        BiometricAttendanceLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("biometric_devices")
}

model BiometricEnrollment {
  id              String  @id @default(uuid())
  employeeId      String
  deviceId        String
  biometricUserId String
  isActive        Boolean @default(true)
  notes           String?

  employee Employee        @relation(fields: [employeeId], references: [id])
  device   BiometricDevice @relation(fields: [deviceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, deviceId])
  @@unique([deviceId, biometricUserId])
  @@map("biometric_enrollments")
}

model BiometricAttendanceLog {
  id              String   @id @default(uuid())
  employeeId      String?
  deviceId        String
  biometricUserId String
  attendanceId    String?
  verified        Boolean  @default(false)
  capturedAt      DateTime
  rawPayload      Json?
  notes           String?

  employee Employee?       @relation(fields: [employeeId], references: [id])
  device   BiometricDevice @relation(fields: [deviceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("biometric_attendance_logs")
}

model DeviceSession {
  id           String   @id @default(uuid())
  userId       String
  deviceName   String?
  ipAddress    String?
  token        String?
  isActive     Boolean  @default(true)
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("device_sessions")
}

model OtpVerification {
  id        String   @id @default(uuid())
  userId    String?
  email     String
  otp       String
  purpose   String
  isUsed    Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("otp_verifications")
}
