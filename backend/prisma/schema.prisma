generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum EmploymentStatus {
  ACTIVE
  ON_PROBATION
  INACTIVE
  RESIGNED
  TERMINATED
}

enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum EmployeeDocumentType {
  AADHAAR
  PAN
  RESUME
  OFFER_LETTER
  EXPERIENCE_LETTER
  CERTIFICATE
  OTHER
}

enum TeamMemberRole {
  TEAM_LEAD
  MEMBER
  INTERN
  FREELANCER
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  HALF_DAY
  LATE
  ON_LEAVE
}

enum AttendanceMethod {
  NORMAL
  QR
  SELFIE
  GPS
  BIOMETRIC
  MANUAL
}

enum AttendanceRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BiometricProvider {
  WEBAUTHN
  MANTRA
  SECUGEN
  ZKTECO
  ESSL
  OTHER
}

enum LeaveStatus {
  PENDING
  TEAM_LEAD_APPROVED
  APPROVED
  REJECTED
  CANCELLED
}

enum LeaveDayType {
  FULL_DAY
  HALF_DAY
}

enum LeaveApprovalAction {
  APPLIED
  TEAM_LEAD_APPROVED
  APPROVED
  REJECTED
  CANCELLED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum LeadSource {
  WEBSITE
  REFERRAL
  SOCIAL_MEDIA
  GOOGLE_ADS
  META_ADS
  EMAIL_CAMPAIGN
  PHONE
  WALK_IN
  OTHER
}

enum ClientStatus {
  PROSPECT
  ACTIVE
  ON_HOLD
  INACTIVE
  CHURNED
}

enum FollowUpType {
  CALL
  EMAIL
  MEETING
  WHATSAPP
  PROPOSAL
  TASK
  OTHER
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  MISSED
  CANCELLED
}

enum SalesPipelineStage {
  LEAD
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum CommercialDocumentType {
  PROPOSAL
  QUOTATION
  CONTRACT
}

enum CommercialDocumentStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
}

enum CommercialApprovalAction {
  CREATED
  UPDATED
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  CANCELLED
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProjectHealth {
  ON_TRACK
  AT_RISK
  OFF_TRACK
}

enum ProjectMemberRole {
  PROJECT_MANAGER
  TEAM_LEAD
  MEMBER
  FREELANCER
}

enum ProjectMilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum TicketStatus {
  OPEN
  ASSIGNED
  IN_PROGRESS
  WAITING_ON_CLIENT
  RESOLVED
  CLOSED
  ESCALATED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketSource {
  INTERNAL
  CLIENT
}

enum TicketSlaEvent {
  STARTED
  AT_RISK
  BREACHED
  MET
  PAUSED
  RESUMED
}

enum TaskStatus {
  BACKLOG
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskRecurrenceType {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

model Role {
  id              String           @id @default(uuid())
  name            String           @unique
  description     String?
  users           User[]
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("roles")
}

model Permission {
  id              String           @id @default(uuid())
  name            String           @unique
  description     String?
  module          String
  action          String
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([module, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model Department {
  id           String        @id @default(uuid())
  name         String        @unique
  description  String?
  employees    Employee[]
  designations Designation[]
  teams        Team[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("departments")
}

model Designation {
  id           String      @id @default(uuid())
  name         String
  description  String?
  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])
  employees    Employee[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@unique([name, departmentId])
  @@map("designations")
}

model Team {
  id           String       @id @default(uuid())
  name         String
  description  String?
  departmentId String
  department   Department   @relation(fields: [departmentId], references: [id])
  members      TeamMember[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@unique([name, departmentId])
  @@map("teams")
}

model TeamMember {
  id         String         @id @default(uuid())
  teamId     String
  employeeId String
  role       TeamMemberRole @default(MEMBER)
  joinedAt   DateTime       @default(now())

  team     Team     @relation(fields: [teamId], references: [id])
  employee Employee @relation(fields: [employeeId], references: [id])

  @@unique([teamId, employeeId])
  @@map("team_members")
}

model ReportingHierarchy {
  id          String  @id @default(uuid())
  employeeId  String  @unique
  reportsToId String?

  employee  Employee  @relation("ReportingEmployee", fields: [employeeId], references: [id])
  reportsTo Employee? @relation("ReportingManager", fields: [reportsToId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reporting_hierarchy")
}

model EmployeeDocument {
  id         String               @id @default(uuid())
  employeeId String
  type       EmployeeDocumentType @default(OTHER)
  name       String
  fileUrl    String?
  fileKey    String?
  notes      String?

  employee Employee @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("employee_documents")
}

model EmployeeSkill {
  id                String     @id @default(uuid())
  employeeId        String
  skillName         String
  level             SkillLevel @default(BEGINNER)
  yearsOfExperience Float?
  notes             String?

  employee Employee @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, skillName])
  @@map("employee_skills")
}

model EmployeeSalaryDetail {
  id            String    @id @default(uuid())
  employeeId    String
  basicSalary   Float
  hra           Float     @default(0)
  allowances    Float     @default(0)
  deductions    Float     @default(0)
  netSalary     Float
  effectiveFrom DateTime
  effectiveTo   DateTime?
  isCurrent     Boolean   @default(true)

  employee Employee @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("employee_salary_details")
}

model User {
  id       String     @id @default(uuid())
  name     String
  email    String     @unique
  phone    String?
  password String
  status   UserStatus @default(ACTIVE)

  roleId String
  role   Role   @relation(fields: [roleId], references: [id])

  employee Employee?

  loginHistory         LoginHistory[]
  deviceSessions       DeviceSession[]
  otpVerifications     OtpVerification[]
  commercialDocuments  CommercialDocument[]
  createdProjects      Project[]            @relation("ProjectCreatedBy")
  projectStatusChanges ProjectStatusLog[]   @relation("ProjectStatusChangedBy")
  createdTickets       Ticket[]             @relation("TicketCreatedBy")
  ticketComments       TicketComment[]
  ticketAttachments    TicketAttachment[]
  ticketStatusChanges  TicketStatusLog[]    @relation("TicketStatusChangedBy")
  createdTasks         Task[]               @relation("TaskCreatedBy")
  taskComments         TaskComment[]
  taskAttachments      TaskAttachment[]
  taskStatusChanges    TaskStatusLog[]      @relation("TaskStatusChangedBy")
  createdRecurringTasks RecurringTask[]     @relation("RecurringTaskCreatedBy")
  notifications         Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model Employee {
  id           String @id @default(uuid())
  userId       String @unique
  employeeCode String @unique

  designationId String?
  designation   Designation? @relation(fields: [designationId], references: [id])

  leaveRequests       LeaveRequest[]     @relation("LeaveRequestEmployee")
  leaveBalances       LeaveBalance[]
  leaveApprovalsGiven LeaveApprovalLog[] @relation("LeaveApprovedBy")

  reportingAsEmployee ReportingHierarchy[] @relation("ReportingEmployee")
  reportingAsManager  ReportingHierarchy[] @relation("ReportingManager")

  joiningDate      DateTime?
  salary           Float?
  skills           String?
  employmentStatus EmploymentStatus @default(ACTIVE)

  managerId    String?
  manager      Employee?  @relation("EmployeeManager", fields: [managerId], references: [id])
  subordinates Employee[] @relation("EmployeeManager")

  documents      EmployeeDocument[]
  employeeSkills EmployeeSkill[]
  salaryDetails  EmployeeSalaryDetail[]

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  user User @relation(fields: [userId], references: [id])

  teamMemberships TeamMember[]

  attendances          Attendance[]
  attendanceRequests   AttendanceRequest[]
  biometricEnrollments BiometricEnrollment[]
  biometricLogs        BiometricAttendanceLog[]

  assignedLeads      Lead[]          @relation("LeadAssignedTo")
  ownedClients       Client[]        @relation("ClientAccountOwner")
  assignedFollowUps  FollowUp[]      @relation("FollowUpAssignedTo")
  ownedPipeline      SalesPipeline[] @relation("SalesPipelineOwner")
  managedProjects    Project[]       @relation("ProjectManager")
  projectMemberships ProjectMember[]
  assignedTickets    Ticket[]        @relation("TicketAssignedTo")
  assignedTasks      Task[]          @relation("TaskAssignedTo")
  assignedRecurringTasks RecurringTask[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("employees")
}

model LeaveType {
  id               String  @id @default(uuid())
  name             String  @unique
  code             String  @unique
  description      String?
  annualQuota      Float   @default(0)
  isPaid           Boolean @default(true)
  requiresApproval Boolean @default(true)
  isActive         Boolean @default(true)

  leaveRequests LeaveRequest[]
  leaveBalances LeaveBalance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("leave_types")
}

model LeaveBalance {
  id             String @id @default(uuid())
  employeeId     String
  leaveTypeId    String
  year           Int
  openingBalance Float  @default(0)
  credited       Float  @default(0)
  used           Float  @default(0)
  pending        Float  @default(0)
  remaining      Float  @default(0)

  employee  Employee  @relation(fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, leaveTypeId, year])
  @@map("leave_balances")
}

model LeaveRequest {
  id          String       @id @default(uuid())
  employeeId  String
  leaveTypeId String
  startDate   DateTime
  endDate     DateTime
  totalDays   Float
  dayType     LeaveDayType @default(FULL_DAY)
  reason      String?
  status      LeaveStatus  @default(PENDING)

  teamLeadRemarks String?
  hrRemarks       String?
  rejectedReason  String?

  teamLeadApprovedAt DateTime?
  hrApprovedAt       DateTime?
  cancelledAt        DateTime?

  employee  Employee  @relation("LeaveRequestEmployee", fields: [employeeId], references: [id])
  leaveType LeaveType @relation(fields: [leaveTypeId], references: [id])

  approvalLogs LeaveApprovalLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("leave_requests")
}

model LeaveApprovalLog {
  id             String              @id @default(uuid())
  leaveRequestId String
  action         LeaveApprovalAction
  remarks        String?
  approvedById   String?

  leaveRequest LeaveRequest @relation(fields: [leaveRequestId], references: [id])
  approvedBy   Employee?    @relation("LeaveApprovedBy", fields: [approvedById], references: [id])

  createdAt DateTime @default(now())

  @@map("leave_approval_logs")
}

model Lead {
  id          String     @id @default(uuid())
  companyName String
  contactName String?
  email       String?
  phone       String?
  website     String?
  source      LeadSource @default(OTHER)
  status      LeadStatus @default(NEW)

  estimatedValue Float?
  notes          String?

  assignedToId String?
  assignedTo   Employee? @relation("LeadAssignedTo", fields: [assignedToId], references: [id])

  convertedClientId String?   @unique
  convertedClient   Client?   @relation("LeadConvertedClient", fields: [convertedClientId], references: [id])
  convertedAt       DateTime?

  followUps           FollowUp[]
  pipelineItems       SalesPipeline[]
  commercialDocuments CommercialDocument[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("leads")
}

model Client {
  id     String       @id @default(uuid())
  name   String
  status ClientStatus @default(PROSPECT)
  source LeadSource   @default(OTHER)

  industry String?
  website  String?
  email    String?
  phone    String?
  address  String?
  notes    String?

  retainerValue Float?
  contractValue Float?
  onboardedAt   DateTime?

  accountOwnerId String?
  accountOwner   Employee? @relation("ClientAccountOwner", fields: [accountOwnerId], references: [id])

  convertedFromLead Lead? @relation("LeadConvertedClient")

  contacts            ClientContact[]
  followUps           FollowUp[]
  pipelineItems       SalesPipeline[]
  commercialDocuments CommercialDocument[]
  projects            Project[]
  tickets             Ticket[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clients")
}

model ClientContact {
  id          String  @id @default(uuid())
  clientId    String
  name        String
  designation String?
  email       String?
  phone       String?
  isPrimary   Boolean @default(false)
  notes       String?

  client Client @relation(fields: [clientId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("client_contacts")
}

model FollowUp {
  id       String  @id @default(uuid())
  leadId   String?
  clientId String?

  subject String
  type    FollowUpType   @default(CALL)
  status  FollowUpStatus @default(PENDING)

  scheduledAt    DateTime
  completedAt    DateTime?
  outcome        String?
  nextFollowUpAt DateTime?
  notes          String?

  assignedToId String?
  assignedTo   Employee? @relation("FollowUpAssignedTo", fields: [assignedToId], references: [id])

  lead   Lead?   @relation(fields: [leadId], references: [id])
  client Client? @relation(fields: [clientId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("follow_ups")
}

model SalesPipeline {
  id          String             @id @default(uuid())
  name        String
  stage       SalesPipelineStage @default(LEAD)
  amount      Float?
  probability Int                @default(10)

  expectedCloseDate DateTime?
  closedAt          DateTime?
  notes             String?

  leadId   String?
  clientId String?
  ownerId  String?

  lead   Lead?     @relation(fields: [leadId], references: [id])
  client Client?   @relation(fields: [clientId], references: [id])
  owner  Employee? @relation("SalesPipelineOwner", fields: [ownerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("sales_pipeline")
}

model CommercialDocument {
  id              String                   @id @default(uuid())
  type            CommercialDocumentType
  documentNumber  String                   @unique
  title           String
  status          CommercialDocumentStatus @default(DRAFT)
  currency        String                   @default("INR")
  issueDate       DateTime                 @default(now())
  validUntil      DateTime?
  startDate       DateTime?
  endDate         DateTime?
  scope           String?
  terms           String?
  notes           String?
  subtotal        Float                    @default(0)
  discountAmount  Float                    @default(0)
  taxPercent      Float                    @default(0)
  taxAmount       Float                    @default(0)
  totalAmount     Float                    @default(0)
  publicToken     String                   @unique @default(uuid())
  sentAt          DateTime?
  viewedAt        DateTime?
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  acceptedByName  String?
  acceptedByEmail String?

  clientId    String?
  client      Client? @relation(fields: [clientId], references: [id])
  leadId      String?
  lead        Lead?   @relation(fields: [leadId], references: [id])
  createdById String?
  createdBy   User?   @relation(fields: [createdById], references: [id])

  items        CommercialDocumentItem[]
  approvalLogs CommercialApprovalLog[]
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt

  @@index([type, status])
  @@map("commercial_documents")
}

model CommercialDocumentItem {
  id          String             @id @default(uuid())
  documentId  String
  description String
  quantity    Float              @default(1)
  unitPrice   Float
  amount      Float
  sortOrder   Int                @default(0)
  document    CommercialDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@map("commercial_document_items")
}

model CommercialApprovalLog {
  id         String                   @id @default(uuid())
  documentId String
  action     CommercialApprovalAction
  actorName  String?
  actorEmail String?
  comments   String?
  ipAddress  String?
  document   CommercialDocument       @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdAt  DateTime                 @default(now())

  @@map("commercial_approval_logs")
}

model Project {
  id          String          @id @default(uuid())
  projectCode String          @unique
  name        String
  description String?
  status      ProjectStatus   @default(PLANNING)
  priority    ProjectPriority @default(MEDIUM)
  health      ProjectHealth   @default(ON_TRACK)
  progress    Int             @default(0)
  startDate   DateTime?
  endDate     DateTime?
  budget      Float?
  actualCost  Float           @default(0)

  clientId    String
  client      Client    @relation(fields: [clientId], references: [id])
  managerId   String?
  manager     Employee? @relation("ProjectManager", fields: [managerId], references: [id])
  createdById String?
  createdBy   User?     @relation("ProjectCreatedBy", fields: [createdById], references: [id])

  members    ProjectMember[]
  milestones    ProjectMilestone[]
  timelines     ProjectTimeline[]
  statusLogs    ProjectStatusLog[]
  tickets       Ticket[]
  tasks         Task[]
  recurringTasks RecurringTask[]
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  @@index([clientId, status])
  @@map("projects")
}

model ProjectMember {
  id         String            @id @default(uuid())
  projectId  String
  employeeId String
  role       ProjectMemberRole @default(MEMBER)
  allocation Int               @default(100)
  joinedAt   DateTime          @default(now())
  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employee   Employee          @relation(fields: [employeeId], references: [id])

  @@unique([projectId, employeeId])
  @@map("project_members")
}

model ProjectMilestone {
  id          String                 @id @default(uuid())
  projectId   String
  title       String
  description String?
  status      ProjectMilestoneStatus @default(PENDING)
  dueDate     DateTime?
  completedAt DateTime?
  sortOrder   Int                    @default(0)
  project     Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       Task[]
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt

  @@map("project_milestones")
}

model ProjectTimeline {
  id        String   @id @default(uuid())
  projectId String
  title     String
  details   String?
  eventDate DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@map("project_timelines")
}

model ProjectStatusLog {
  id          String         @id @default(uuid())
  projectId   String
  fromStatus  ProjectStatus?
  toStatus    ProjectStatus
  remarks     String?
  changedById String?
  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  changedBy   User?          @relation("ProjectStatusChangedBy", fields: [changedById], references: [id])
  createdAt   DateTime       @default(now())

  @@map("project_status_logs")
}

model TicketCategory {
  id              String   @id @default(uuid())
  name            String   @unique
  description     String?
  defaultSlaHours Int      @default(24)
  isActive        Boolean  @default(true)
  tickets         Ticket[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("ticket_categories")
}

model Ticket {
  id                 String         @id @default(uuid())
  ticketNumber       String         @unique
  title              String
  description        String
  status             TicketStatus   @default(OPEN)
  priority           TicketPriority @default(MEDIUM)
  source             TicketSource   @default(INTERNAL)
  dueAt              DateTime?
  firstResponseDueAt DateTime?
  resolutionDueAt    DateTime?
  firstRespondedAt   DateTime?
  resolvedAt         DateTime?
  closedAt           DateTime?
  escalationLevel    Int            @default(0)
  categoryId         String?
  category           TicketCategory? @relation(fields: [categoryId], references: [id])
  clientId           String?
  client             Client?         @relation(fields: [clientId], references: [id])
  projectId          String?
  project            Project?        @relation(fields: [projectId], references: [id])
  assignedToId       String?
  assignedTo         Employee?       @relation("TicketAssignedTo", fields: [assignedToId], references: [id])
  createdById        String?
  createdBy          User?           @relation("TicketCreatedBy", fields: [createdById], references: [id])
  comments           TicketComment[]
  attachments        TicketAttachment[]
  slaLogs            TicketSlaLog[]
  statusLogs         TicketStatusLog[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([status, priority])
  @@index([assignedToId, status])
  @@map("tickets")
}

model TicketComment {
  id         String   @id @default(uuid())
  ticketId   String
  authorId   String?
  body       String
  isInternal Boolean  @default(false)
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  author     User?    @relation(fields: [authorId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("ticket_comments")
}

model TicketAttachment {
  id           String   @id @default(uuid())
  ticketId     String
  uploadedById String?
  name         String
  fileUrl      String
  fileType     String?
  fileSize     Int?
  ticket       Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@map("ticket_attachments")
}

model TicketSlaLog {
  id        String         @id @default(uuid())
  ticketId  String
  event     TicketSlaEvent
  notes     String?
  ticket    Ticket         @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@map("ticket_sla_logs")
}

model TicketStatusLog {
  id          String        @id @default(uuid())
  ticketId    String
  fromStatus  TicketStatus?
  toStatus    TicketStatus
  remarks     String?
  changedById String?
  ticket      Ticket        @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  changedBy   User?         @relation("TicketStatusChangedBy", fields: [changedById], references: [id])
  createdAt   DateTime      @default(now())

  @@map("ticket_status_logs")
}

model Task {
  id            String        @id @default(uuid())
  taskNumber    String        @unique
  title         String
  description   String?
  status        TaskStatus    @default(TODO)
  priority      TaskPriority  @default(MEDIUM)
  dueDate       DateTime?
  estimatedHrs  Float?
  actualHrs     Float?
  sortOrder     Int           @default(0)

  projectId     String?
  project       Project?      @relation(fields: [projectId], references: [id])
  milestoneId   String?
  milestone     ProjectMilestone? @relation(fields: [milestoneId], references: [id])
  assignedToId  String?
  assignedTo    Employee?     @relation("TaskAssignedTo", fields: [assignedToId], references: [id])
  createdById   String?
  createdBy     User?         @relation("TaskCreatedBy", fields: [createdById], references: [id])
  parentId      String?
  parent        Task?         @relation("TaskParent", fields: [parentId], references: [id])
  subTasks      Task[]        @relation("TaskParent")

  comments      TaskComment[]
  attachments   TaskAttachment[]
  dependencies  TaskDependency[]  @relation("TaskDependsOn")
  dependentBy   TaskDependency[]  @relation("TaskDependedBy")
  statusLogs    TaskStatusLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, priority])
  @@index([assignedToId, status])
  @@index([projectId])
  @@map("tasks")
}

model TaskComment {
  id         String   @id @default(uuid())
  taskId     String
  authorId   String?
  body       String
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author     User?    @relation(fields: [authorId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("task_comments")
}

model TaskAttachment {
  id           String   @id @default(uuid())
  taskId       String
  uploadedById String?
  name         String
  fileUrl      String
  fileType     String?
  fileSize     Int?
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@map("task_attachments")
}

model TaskDependency {
  id            String     @id @default(uuid())
  taskId        String
  dependsOnId   String
  dependencyType String    @default("BLOCKS")
  task          Task       @relation("TaskDependsOn", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn     Task       @relation("TaskDependedBy", fields: [dependsOnId], references: [id], onDelete: Cascade)
  createdAt     DateTime   @default(now())

  @@unique([taskId, dependsOnId])
  @@map("task_dependencies")
}

model TaskStatusLog {
  id          String      @id @default(uuid())
  taskId      String
  fromStatus  TaskStatus?
  toStatus    TaskStatus
  remarks     String?
  changedById String?
  task        Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  changedBy   User?       @relation("TaskStatusChangedBy", fields: [changedById], references: [id])
  createdAt   DateTime    @default(now())

  @@map("task_status_logs")
}

model RecurringTask {
  id              String              @id @default(uuid())
  title           String
  description     String?
  priority        TaskPriority        @default(MEDIUM)
  recurrenceType  TaskRecurrenceType
  intervalValue   Int?                @default(1)
  customCron      String?
  startDate       DateTime
  endDate         DateTime?
  nextOccurrence  DateTime
  isActive        Boolean             @default(true)

  projectId       String?
  project         Project?            @relation(fields: [projectId], references: [id])
  assignedToId    String?
  assignedTo      Employee?           @relation(fields: [assignedToId], references: [id])
  createdById     String?
  createdBy       User?               @relation("RecurringTaskCreatedBy", fields: [createdById], references: [id])

  lastGeneratedAt DateTime?
  totalGenerated  Int                 @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@map("recurring_tasks")
}

model LoginHistory {
  id        String   @id @default(uuid())
  userId    String
  ipAddress String?
  device    String?
  browser   String?
  os        String?
  loginAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("login_history")
}

model Attendance {
  id             String   @id @default(uuid())
  employeeId     String
  attendanceDate DateTime

  checkInTime  DateTime?
  checkOutTime DateTime?

  checkInMethod  AttendanceMethod?
  checkOutMethod AttendanceMethod?

  totalBreakMins Int @default(0)
  totalWorkMins  Int @default(0)

  status    AttendanceStatus @default(PRESENT)
  isLate    Boolean          @default(false)
  isHalfDay Boolean          @default(false)

  checkInQrSessionId  String?
  checkOutQrSessionId String?

  checkInSelfieUrl  String?
  checkOutSelfieUrl String?

  checkInLatitude   Float?
  checkInLongitude  Float?
  checkOutLatitude  Float?
  checkOutLongitude Float?

  checkInAccuracyM  Float?
  checkOutAccuracyM Float?

  checkInLocationVerified  Boolean @default(false)
  checkOutLocationVerified Boolean @default(false)

  checkInBiometricVerified  Boolean @default(false)
  checkOutBiometricVerified Boolean @default(false)

  checkInBiometricDeviceId  String?
  checkOutBiometricDeviceId String?

  checkInBiometricUserId  String?
  checkOutBiometricUserId String?

  checkInBiometricLogId  String?
  checkOutBiometricLogId String?

  ipAddress  String?
  deviceInfo String?
  notes      String?

  employee Employee          @relation(fields: [employeeId], references: [id])
  breaks   AttendanceBreak[]

  checkInQrSession  AttendanceQrSession? @relation("CheckInQrSession", fields: [checkInQrSessionId], references: [id])
  checkOutQrSession AttendanceQrSession? @relation("CheckOutQrSession", fields: [checkOutQrSessionId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, attendanceDate])
  @@map("attendance")
}

model AttendanceBreak {
  id           String    @id @default(uuid())
  attendanceId String
  breakStart   DateTime
  breakEnd     DateTime?
  durationMins Int       @default(0)
  notes        String?

  attendance Attendance @relation(fields: [attendanceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("attendance_breaks")
}

model AttendanceSetting {
  id              String @id @default(uuid())
  officeStartTime String @default("10:00")
  officeEndTime   String @default("19:00")
  lateAfterMins   Int    @default(15)
  halfDayMins     Int    @default(270)
  fullDayMins     Int    @default(480)

  officeLatitude  Float?
  officeLongitude Float?
  gpsRadiusMeters Int    @default(200)

  allowNormalAttendance      Boolean @default(true)
  requireQrAttendance        Boolean @default(false)
  requireSelfieAttendance    Boolean @default(false)
  requireGpsAttendance       Boolean @default(false)
  requireBiometricAttendance Boolean @default(false)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("attendance_settings")
}

model AttendanceQrSession {
  id        String   @id @default(uuid())
  token     String   @unique
  title     String?
  validFrom DateTime
  expiresAt DateTime
  isActive  Boolean  @default(true)

  createdById String?
  notes       String?

  checkInAttendances  Attendance[] @relation("CheckInQrSession")
  checkOutAttendances Attendance[] @relation("CheckOutQrSession")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("attendance_qr_sessions")
}

model AttendanceRequest {
  id             String                  @id @default(uuid())
  employeeId     String
  attendanceDate DateTime
  requestType    String
  reason         String?
  status         AttendanceRequestStatus @default(PENDING)

  requestedCheckInTime  DateTime?
  requestedCheckOutTime DateTime?

  approvedById String?
  approvedAt   DateTime?
  remarks      String?

  employee Employee @relation(fields: [employeeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("attendance_requests")
}

model BiometricDevice {
  id           String            @id @default(uuid())
  name         String
  provider     BiometricProvider @default(OTHER)
  model        String?
  serialNumber String?           @unique
  location     String?
  apiBaseUrl   String?
  apiKey       String?
  isActive     Boolean           @default(true)

  enrollments BiometricEnrollment[]
  logs        BiometricAttendanceLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("biometric_devices")
}

model BiometricEnrollment {
  id              String  @id @default(uuid())
  employeeId      String
  deviceId        String
  biometricUserId String
  isActive        Boolean @default(true)
  notes           String?

  employee Employee        @relation(fields: [employeeId], references: [id])
  device   BiometricDevice @relation(fields: [deviceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([employeeId, deviceId])
  @@unique([deviceId, biometricUserId])
  @@map("biometric_enrollments")
}

model BiometricAttendanceLog {
  id              String   @id @default(uuid())
  employeeId      String?
  deviceId        String
  biometricUserId String
  attendanceId    String?
  verified        Boolean  @default(false)
  capturedAt      DateTime
  rawPayload      Json?
  notes           String?

  employee Employee?       @relation(fields: [employeeId], references: [id])
  device   BiometricDevice @relation(fields: [deviceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("biometric_attendance_logs")
}

model DeviceSession {
  id           String   @id @default(uuid())
  userId       String
  deviceName   String?
  ipAddress    String?
  token        String?
  isActive     Boolean  @default(true)
  lastActiveAt DateTime @default(now())
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("device_sessions")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  message   String
  type      String   @default("INFO")
  link      String?
  isRead    Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@map("notifications")
}

model OtpVerification {
  id        String   @id @default(uuid())
  userId    String?
  email     String
  otp       String
  purpose   String
  isUsed    Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("otp_verifications")
}
