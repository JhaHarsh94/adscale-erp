# ============================================================
# AdScale ERP Backend — Environment Variables
# Copy to .env and fill in values
# ============================================================

PORT=5000
NODE_ENV=production

# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/adscale_erp?schema=public"

# JWT — Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="CHANGE_ME_GENERATE_RANDOM_64_CHAR_HEX"
JWT_EXPIRES_IN="7d"

# AES-256-GCM key for biometric API keys — Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="CHANGE_ME_GENERATE_RANDOM_64_CHAR_HEX"

# Email — leave blank to use console OTP mode in development
EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT=587
EMAIL_USER=""
EMAIL_PASS=""
EMAIL_FROM="AdScale One ERP <no-reply@adscale.com>"

OTP_EXPIRES_MINUTES=10

# CORS — comma separated allowed frontend origins
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"
